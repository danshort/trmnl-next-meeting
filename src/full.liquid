<div class="layout layout--col layout--top">

  {%- comment -%} ===== Weather strip (Tempest): now on top, today below ===== {%- endcomment -%}
  <div class="w--full" style="border-bottom: 1px solid black; padding-bottom: 10px; margin-bottom: 1.5em;">
    <div class="flex flex--row flex--center-x flex--center-y gap--small" style="margin-bottom: 4px;">
      <img class="image" src="{{ wx_now_icon }}" style="width: 30px; height: 30px;">
      <span class="value value--small">{{ wx_now_conditions }}</span>
      {%- comment -%} thermometer glyph + temp {%- endcomment -%}
      <span class="flex flex--row flex--center-y gap--xsmall">
        <img class="image" src="https://trmnl.com/images/plugins/weather/wi-thermometer.svg" style="width: 30px; height: 30px;">
        <span class="value value--small">{{ wx_temp }}° feels {{ wx_feels }}°</span>
      </span>
      {%- comment -%} humidity glyph + humidity {%- endcomment -%}
      <span class="flex flex--row flex--center-y gap--xsmall">
        <img class="image" src="https://trmnl.com/images/plugins/weather/wi-humidity.svg" style="width: 30px; height: 30px;">
        <span class="value value--small">{{ wx_humidity }}% humidity</span>
      </span>
    </div>
    <div class="flex flex--row flex--center-x flex--center-y gap--small">
      <img class="image" src="{{ wx_today_icon }}" style="width: 30px; height: 30px;">
      <span class="value value--small">{{ wx_today_conditions }}</span>
      {%- comment -%} today's high above 85° swaps the thermometer for the "hot" glyph {%- endcomment -%}
      {% if wx_high > 85 %}
        {% assign today_temp_icon = "https://trmnl.com/images/plugins/weather/wi-hot.svg" %}
      {% else %}
        {% assign today_temp_icon = "https://trmnl.com/images/plugins/weather/wi-thermometer.svg" %}
      {% endif %}
      <span class="flex flex--row flex--center-y gap--xsmall">
        <img class="image" src="{{ today_temp_icon }}" style="width: 30px; height: 30px;">
        <span class="value value--small">H {{ wx_high }}° L {{ wx_low }}°</span>
      </span>
      <span class="flex flex--row flex--center-y gap--xsmall">
        <img class="image" src="https://trmnl.com/images/plugins/weather/wi-raindrop.svg" style="width: 30px; height: 30px;">
        <span class="value value--small">{{ wx_rain }}% rain</span>
      </span>
    </div>
  </div>

  {%- comment -%} ===== Availability hero — grows to fill remaining space and centers vertically ===== {%- endcomment -%}
  <div class="grow flex flex--col flex--center-y w--full">
    <div class="columns">
      <div class="column">
        <div class="richtext text--center">
          {% if is_busy %}
            <span class="value value--xxlarge">In a meeting</span>
            <span class="value value--large">until {{ current_event.end }}</span>
          {% elsif next_event %}
            <span class="value value--xxlarge">Available</span>
            <span class="value value--large">until {{ next_event.start }}{% if next_is_other_day %} {{ next_day_label }}{% endif %}</span>
          {% else %}
            <span class="value value--xxlarge">Available</span>
            <span class="value value--large">nothing scheduled</span>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ===== Now / Next detail ===== {%- endcomment -%}
  <div class="columns">
    <div class="column">
      <div class="richtext">
        <div style="display: flex; align-items: baseline; justify-content: center; gap: 10px;">
          <span class="value value--small">Now</span>
          {% if current_event %}
            <span class="value value--small value--tnums">: {{ current_event.start }} – {{ current_event.end }}</span>
          {% endif %}
        </div>
        {% if current_event %}
          <span class="value value--medium clamp--2 text--center">{{ current_event.summary }}</span>
        {% else %}
          <span class="value value--small text--center">Free</span>
        {% endif %}
      </div>
    </div>
    <div class="column">
      <div class="richtext">
        <div style="display: flex; align-items: baseline; justify-content: center; gap: 10px;">
          <span class="value value--small">Next</span>
          {% if next_event %}
            <span class="value value--small value--tnums">: {% if next_is_other_day %}{{ next_day_label }} · {% endif %}{{ next_event.start }} – {{ next_event.end }}</span>
          {% endif %}
        </div>
        {% if next_event %}
          <span class="value value--medium clamp--2 text--center">{{ next_event.summary }}</span>
        {% else %}
          <span class="value value--small text--center">{{ empty_label }}</span>
        {% endif %}
      </div>
    </div>
  </div>

</div>

<div class="title_bar" style="height: 72px;">
  <img class="image" src="https://dansshorts.com/assets/gfx/dan.gif" style="height: 56px !important; width: auto !important; max-height: none !important;">
  <span class="title">Availability</span>
  <span class="instance">{{ 'updated' | l_word: trmnl.user.locale }}: {{ "now" | date: "%s" | plus: trmnl.user.utc_offset | date: "%I:%M %p" }}</span>
</div>
